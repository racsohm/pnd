# ── App ──────────────────────────────────────────────────────────
APP_NAME="PND Respaldos"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8090
APP_TIMEZONE=America/Mexico_City
APP_LOCALE=es

LOG_CHANNEL=stack
LOG_LEVEL=info

# ── Auth admin (sembrado en primer arranque) ─────────────────────
ADMIN_NAME="Administrador"
ADMIN_EMAIL=admin@dataismo.mx
ADMIN_PASSWORD=cambia-esto-por-favor

# ── DB (SQLite local) ────────────────────────────────────────────
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/sqlite/database.sqlite

# ── Sesión ───────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ── Backups ──────────────────────────────────────────────────────
BACKUPS_PATH=/var/backups
INSTANCES_PATH=/host/instances
MONGO_TOOLS_TIMEOUT=600

# ── Networking ───────────────────────────────────────────────────
# IMPORTANTE: con HTTP plano, todo viaja en claro (login, descargas).
# - BIND_ADDRESS=127.0.0.1 → solo accesible desde el host (recomendado;
#   exponer luego con nginx + TLS).
# - BIND_ADDRESS=0.0.0.0   → accesible desde la IP pública del VPS
#   (rápido para arrancar, INSEGURO para datos personales).
BIND_ADDRESS=127.0.0.1
HOST_PORT=8090

# Path en el host donde viven las instancias PND (auto-discovery).
INSTANCES_HOST_PATH=/opt

# Tamaño máximo permitido para subir respaldos (MB).
UPLOAD_MAX_MB=512
