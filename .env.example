# ── Credenciales compartidas de MongoDB ──────────────────────────
# Generadas automáticamente por setup.sh / asistente.sh en el primer
# arranque. NO editar después de inicializar Mongo (la imagen oficial
# fija el usuario root sólo en el primer arranque).
DB_ROOT_USER=pdnmx_admin
DB_ROOT_PASSWORD=<generada-con-openssl-rand-hex-16>
DB_PORT=27017
